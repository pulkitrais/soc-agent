# ============================================================
# Sentinel Investigator - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit your .env file to source control
# ============================================================

# ── Azure Authentication ────────────────────────────────────
# Authentication method: device_code | service_principal | managed_identity
AZURE_AUTH_METHOD=device_code

# Required for service_principal auth
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ── Microsoft Sentinel Workspaces ──────────────────────────
# Default workspace (can be overridden in UI)
SENTINEL_WORKSPACE_ID=your-workspace-id-here
SENTINEL_RESOURCE_GROUP=your-resource-group
SENTINEL_SUBSCRIPTION_ID=your-subscription-id

# ── OpenAI (NL→KQL generation) ──────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Threat Intel Enrichment ─────────────────────────────────
VIRUSTOTAL_API_KEY=your-virustotal-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# ── Application Settings ────────────────────────────────────
APP_NAME=Sentinel Investigator
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Data persistence directory (relative to project root)
DATA_DIR=data
